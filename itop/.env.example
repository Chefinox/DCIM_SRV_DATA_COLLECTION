# iTop deployment
TZ=Asia/Jakarta
ITOP_URL=http://localhost:8080
ITOP_HTTP_BIND=127.0.0.1
ITOP_HTTP_PORT=8080

# MariaDB
ITOP_DB_NAME=itop
ITOP_DB_USER=itop
ITOP_DB_PASSWORD=change-me-strong-db-password
ITOP_DB_ROOT_PASSWORD=change-me-strong-root-password
MARIADB_INNODB_BUFFER_POOL_SIZE=512M
MARIADB_INNODB_LOG_FILE_SIZE=256M
MARIADB_MAX_CONNECTIONS=200

# iTop admin and sync account
ITOP_ADMIN_USER=admin
ITOP_ADMIN_PASSWORD=change-me-strong-admin-password
ITOP_SYNC_USER=admin
ITOP_SYNC_PASSWORD=change-me-strong-admin-password

# NetBox source
NETBOX_URL=http://10.70.0.20:9008/
NETBOX_TOKEN=change-me-netbox-token

# Sync service
SYNC_INTERVAL_SECONDS=3600
LOG_LEVEL=INFO

# PHP runtime
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M
