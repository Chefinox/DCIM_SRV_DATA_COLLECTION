{
  "topic_to_device_type": {
    "dcim.raw.network": "network_switch",
    "dcim.raw.power.ups": "ups",
    "dcim.raw.storage.nas": "nas",
    "dcim.raw.server": "server",
    "dcim.raw.cctv": "cctv",
    "dcim.raw.device.isapi": "cctv"
  },
  "measurement_to_device_type": {
    "interface": "network_switch",
    "ups_apc": "ups",
    "dcim_nas": "nas",
    "dcim_nas_volume": "nas",
    "nas_snmp": "nas",
    "mikrotik": "network_switch",
    "server_redfish": "server",
    "server_redfish_util": "server",
    "server_inventory": "server",
    "cctv_metrics": "cctv"
  },
  "dcim_nas": {
    "metric_name": "disk_temperature",
    "metric_field": "diskTemp",
    "metric_unit": "celsius",
    "severity_field": "diskStatus",
    "severity_map": {
      "1": "info",
      "2": "warning",
      "3": "critical"
    }
  },
  "dcim_nas_volume": {
    "metric_name": "volume_usage_pct",
    "metric_field": "volumeUsagePct",
    "metric_unit": "percent",
    "secondary_metrics": [
      {
        "field": "volumeUsedBytes",
        "name": "volume_used",
        "unit": "bytes"
      },
      {
        "field": "volumeTotalBytes",
        "name": "volume_total",
        "unit": "bytes"
      },
      {
        "field": "volumeUsedGB",
        "name": "volume_used_gb",
        "unit": "gigabytes"
      },
      {
        "field": "volumeTotalTB",
        "name": "volume_total_tb",
        "unit": "terabytes"
      },
      {
        "field": "volumeStatus",
        "name": "volume_health",
        "unit": "status_code"
      }
    ]
  },
  "nas_snmp": {
    "metric_name": "system_temperature",
    "metric_field": "system_temp",
    "metric_unit": "celsius"
  },
  "ups_apc": {
    "metric_name": "battery_capacity",
    "metric_field": "battery_capacity",
    "metric_unit": "percent",
    "secondary_metrics": [
      {
        "field": "battery_temp",
        "name": "battery_temperature",
        "unit": "celsius"
      },
      {
        "field": "output_voltage",
        "name": "output_voltage",
        "unit": "volt"
      },
      {
        "field": "battery_runtime_remain",
        "name": "battery_runtime_remaining",
        "unit": "seconds"
      },
      {
        "field": "battery_voltage",
        "name": "battery_voltage",
        "unit": "volt"
      },
      {
        "field": "battery_current",
        "name": "battery_current",
        "unit": "ampere"
      },
      {
        "field": "output_frequency",
        "name": "output_frequency",
        "unit": "hertz"
      },
      {
        "field": "output_load",
        "name": "output_load",
        "unit": "percent"
      }
    ]
  },
  "interface": {
    "metric_name": "interface_status",
    "metric_field": "ifOperStatus",
    "metric_unit": "status_code"
  },
  "cctv_metrics": {
    "metric_name": "status_online",
    "metric_field": "status_online",
    "metric_unit": "status_code",
    "secondary_metrics": [
      {
        "field": "cpuUtilization",
        "name": "cpu_utilization",
        "unit": "percent"
      },
      {
        "field": "memoryUsage",
        "name": "memory_usage",
        "unit": "gigabytes"
      },
      {
        "field": "memoryUsagePct",
        "name": "memory_usage_pct",
        "unit": "percent"
      },
      {
        "field": "memoryAvailable",
        "name": "memory_available",
        "unit": "gigabytes"
      }
    ]
  },
  "mikrotik": {
    "metric_name": "cpu_load",
    "metric_field": "cpu_load",
    "metric_unit": "percent",
    "secondary_metrics": [
      {
        "field": "memory_used_kb",
        "name": "memory_used",
        "unit": "kilobytes"
      },
      {
        "field": "memory_total_kb",
        "name": "memory_total",
        "unit": "kilobytes"
      },
      {
        "field": "uptime_seconds",
        "name": "uptime",
        "unit": "seconds"
      }
    ]
  },
  "server_redfish": {
    "metric_name": "power_state",
    "metric_field": "power_state",
    "metric_unit": "status_code"
  },
  "default": {
    "metric_name": "general_metric",
    "metric_field": null,
    "metric_unit": null
  },
  "server_redfish_util": {
    "metric_name": "cpu_utilization",
    "metric_field": "cpuUtilization",
    "metric_unit": "percent",
    "secondary_metrics": [
      {
        "field": "memoryUsage",
        "name": "memory_utilization",
        "unit": "percent"
      }
    ]
  },
  "server_inventory": {
    "metric_name": "inventory_snapshot",
    "metric_field": null
  }
}
