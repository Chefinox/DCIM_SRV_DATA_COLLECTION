[[inputs.exec]]
  commands  = ["/usr/local/bin/nas_inventory_poller.py"]
  timeout   = "120s"
  interval  = "300s"
  data_format = "json"
  name_override = "nas_metrics"
  tag_keys = ["measurement", "serial_number", "hostname", "ip", "device_type", "category", "volume_id", "disk_id"]
  json_string_fields = ["model", "manufacturer", "firmware", "status", "uptime"]
  json_time_key = "timestamp"
  json_time_format = "2006-01-02T15:04:05Z"

[[outputs.file]]
  files = ["stdout"]
